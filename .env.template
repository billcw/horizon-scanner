# =============================================================================
# HORIZON SCANNER — .env.template
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub — it is in .gitignore.
# =============================================================================

# Anthropic (required for L2 classifier and L3 thesis loops)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Perplexity (used for real-time web search inside thesis loops)
# Get at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Reddit (optional - public API works without keys at lower rate limits)
# Get at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=HorizonScanner/1.0

# USPTO (optional - public access works without key at lower limits)
USPTO_API_KEY=your_uspto_api_key_here

# Crunchbase (Phase 4 - leave blank for now)
CRUNCHBASE_API_KEY=

# Google (Phase 4 - leave blank for now)
GOOGLE_API_KEY=
